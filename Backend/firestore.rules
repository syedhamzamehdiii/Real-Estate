rules_version = '2';

/**
 * Estate Line Properties — Firestore security rules
 *
 * Access model:
 * - Public: read listings, resources, meta
 * - Contact: anyone may create an inquiry
 * - Lead clicks: anyone may create a unique call/WhatsApp click (once per visitor)
 * - Signed-in admin: write listings/resources/meta; read/update inquiries; read lead clicks
 *
 * Listing/resource field shape is enforced in the Zod client layer.
 * Rules keep auth + basic identity checks so optional media fields
 * (long Storage URLs, thumbnails, etc.) do not cause intermittent
 * permission-denied failures.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isString(value) {
      return value is string;
    }

    function isNonEmptyString(value, maxLen) {
      return isString(value)
        && value.size() > 0
        && value.size() <= maxLen;
    }

    function validInquiryWrite() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'email', 'phone', 'message', 'interest', 'createdAt', 'status'])
        && isNonEmptyString(d.name, 120)
        && isNonEmptyString(d.email, 200)
        && d.email.matches('.*@.*\\..*')
        && isNonEmptyString(d.phone, 40)
        && isNonEmptyString(d.message, 5000)
        && isNonEmptyString(d.interest, 120)
        && d.status == 'new'
        && d.createdAt is timestamp
        && !('ownerId' in d);
    }

    function validLeadClickWrite() {
      let d = request.resource.data;
      return d.keys().hasOnly(['channel', 'visitorId', 'createdAt'])
        && (d.channel == 'call' || d.channel == 'whatsapp')
        && isNonEmptyString(d.visitorId, 80)
        && d.visitorId.size() >= 8
        && d.createdAt is timestamp
        && request.resource.id == d.visitorId + '__' + d.channel;
    }

    function validListingsMeta() {
      let d = request.resource.data;
      return d.keys().hasOnly(['featuredOrder', 'mainAreas', 'updatedAt'])
        && d.featuredOrder is list
        && d.featuredOrder.size() <= 3
        && d.mainAreas is list
        && d.mainAreas.size() <= 200
        && d.updatedAt is timestamp;
    }

    function validResourcesMeta() {
      let d = request.resource.data;
      return d.keys().hasOnly(['featuredOrder', 'nextNumericId', 'updatedAt'])
        && d.featuredOrder is list
        && d.featuredOrder.size() <= 5
        && d.nextNumericId is number
        && d.nextNumericId >= 1
        && d.updatedAt is timestamp;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.id == listingId
        && request.resource.data.keys().hasAll([
          'id', 'title', 'location', 'locationKey', 'type', 'status',
          'priceLabel', 'priceValue', 'image', 'sizeLabel', 'description',
          'createdAt', 'updatedAt', 'ownerId'
        ]);
      allow delete: if isSignedIn();
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.id == resourceId
        && request.resource.data.keys().hasAll([
          'id', 'slug', 'category', 'title', 'excerpt', 'content',
          'image', 'author', 'readMinutes', 'publishedAt',
          'createdAt', 'updatedAt', 'ownerId'
        ]);
      allow delete: if isSignedIn();
    }

    match /meta/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && (
          (docId == 'listings' && validListingsMeta())
          || (docId == 'resources' && validResourcesMeta())
        );
      allow delete: if false;
    }

    match /inquiries/{inquiryId} {
      allow create: if validInquiryWrite();
      allow read, update, delete: if isSignedIn();
    }

    match /contactLeadClicks/{clickId} {
      allow create: if validLeadClickWrite();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
