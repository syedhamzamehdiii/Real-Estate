rules_version = '2';

/**
 * Estate Line Properties — Firebase Storage rules
 *
 * Layout:
 *   listings/{listingId}/cover.jpg
 *   listings/{listingId}/cover-thumb.jpg
 *   listings/{listingId}/gallery/{fileName}
 *   resources/{resourceId}/cover.jpg
 *   resources/{resourceId}/cover-thumb.jpg
 *
 * Public read. Any signed-in admin may upload/replace/delete under these paths.
 */
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function underLimit() {
      return request.resource.size < 12 * 1024 * 1024;
    }

    match /listings/{listingId}/cover.jpg {
      allow read: if true;
      allow create, update: if isSignedIn() && underLimit();
      allow delete: if isSignedIn();
    }

    match /listings/{listingId}/cover-thumb.jpg {
      allow read: if true;
      allow create, update: if isSignedIn() && underLimit();
      allow delete: if isSignedIn();
    }

    match /listings/{listingId}/gallery/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && underLimit()
        && fileName.matches('^[a-zA-Z0-9._-]{1,120}$');
      allow delete: if isSignedIn();
    }

    match /resources/{resourceId}/cover.jpg {
      allow read: if true;
      allow create, update: if isSignedIn() && underLimit();
      allow delete: if isSignedIn();
    }

    match /resources/{resourceId}/cover-thumb.jpg {
      allow read: if true;
      allow create, update: if isSignedIn() && underLimit();
      allow delete: if isSignedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
